{
    "terminal.integrated.defaultProfile.linux": "zsh",
    "terminal.integrated.fontFamily": "'FiraCode Nerd Font Mono'",
    "customPresentationMode.overrides": {
        "workbench.colorTheme": "Visual Studio Light",
        "window.zoomLevel": 1,
        "debug.console.fontSize": 26,
        "editor.fontSize": 26,
        "markdown.preview.fontSize": 26,
        "terminal.integrated.fontSize": 26,
        "gitlens.codeLens.enabled": false,
        "gitlens.currentLine.enabled": false
    },
    "gitlens.codeLens.authors.command": false,
    "window.autoDetectColorScheme": true,
    "editor.fontLigatures": true,
    "code-runner.executorMap": {
      "python": "python3 -u"
    },
    "code-runner.runInTerminal": true,
    "files.autoSave": "afterDelay",
    "editor.wordWrap": "on",
    "git.autofetch": true,


    "latex-workshop.latex.tools": [
      {
          "name": "latexmk",
          "command": "latexmk",
          "args": [
              "-pdflatex=lualatex",
              "--shell-escape",
              "-f",
              "-synctex=1",
              "-interaction=nonstopmode",
              "-file-line-error",
              "-pdf",
              "%DOC%"
          ]
      },
      {
          "name": "pdflatex",
          "command": "pdflatex",
          "args": [
              "--shell-escape",
              "-synctex=1",
              "-interaction=nonstopmode",
              "-file-line-error",
              "%DOC%"
          ]
      },
      {
          "name": "bibtex",
          "command": "bibtex",
          "args": [
              "%DOCFILE%"
          ]
      }
    ],

    "ltex.enabled": [
        "latex",
        "markdown",
        "plaintext"
    ],
    "ltex.language": "en-US",
    "ltex.additionalRules.enablePickyRules": true,
    "ltex.additionalRules.languageModel": "/home/yeshey/.local/share/vscodium-nix-deps/ngram-en",
    "ltex.ltex-ls.path": "/home/yeshey/.local/share/vscodium-nix-deps/ltex-ls-plus",

    "nix.enableLanguageServer": true,
    "nix.serverPath": "nixd",
    "nix.serverSettings": {
        "nixd": {
            "options": {
                "flake": {
                "autoArchive": true
                }
            },
            "formatting": {
                "command": "nixfmt-rfc-style"
            }
        }
    },
    "git.enableSmartCommit": true,
    "redhat.telemetry.enabled": true,
    "diffEditor.ignoreTrimWhitespace": false
}
